{
	"agent": {
		"default_model": {
			"provider": "google",
			"model": "gemini-2.5-flash",
			"enable_thinking": true,
		},
		"favorite_models": [],
		"model_parameters": [],
	},
	"agent_servers": {
		"gemini": {
			"type": "registry",
		},
	},
	"git_panel": {
		"tree_view": true,
	},
	"ui_font_family": "JetBrainsMonoNL Nerd Font",
	"buffer_font_family": "JetBrainsMonoNL Nerd Font",
	"project_panel": {
		"auto_fold_dirs": false,
	},
	"icon_theme": "Material Icon Theme",
	"ui_font_size": 20,
	"buffer_font_size": 15,
	"theme": {
		"mode": "system",
		"light": "Ayu Mirage",
		"dark": "One Dark",
	},
	"file_types": {
		"kulala-http": ["http", "rest"],
	},
	"lsp": {
		"kulala-ls": {
			"binary": {
				"path": "/home/mgajozo/.nvm/versions/node/v24.12.0/bin/kulala-ls",
				"arguments": ["--stdio"],
			},
		},
	},
	"languages": {
		"kulala-http": {
			"language_servers": ["kulala-ls"],
			"formatter": {
				"external": {
					"command": "/home/mgajozo/.nvm/versions/node/v24.12.0/bin/kulala-fmt",
					"arguments": ["format", "--stdin", "{buffer_path}"],
				},
			},
			"format_on_save": "on",
		},
	},
